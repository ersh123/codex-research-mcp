# Exa CLI wrapper configuration
EXA_API_KEY=
EXA_SEARCH_BIN=exa-search
EXA_FETCH_BIN=exa-fetch

# XMLstock Google XML. Reuses the same XMLstock account/key class as other XMLstock search endpoints.
XMLSTOCK_USER=
XMLSTOCK_KEY=
XMLSTOCK_GOOGLE_XML_ENDPOINT=https://xmlstock.com/google/xml/

# Backward-compatible aliases used by older XMLstock setups.
XMLSTOCK_YANDEX_XML_USER=
XMLSTOCK_YANDEX_XML_KEY=

# Optional fallback: Google Programmable Search / Custom Search JSON API
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=

# Optional LLM planner for dynamic subagent lanes.
# Put real values in ~/.config/codex-research-mcp/llm.env, not in the repo.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Optional: override default ~/.cache/codex-research-mcp/runs
SEARCH_LOCAL_CACHE_ROOT=
